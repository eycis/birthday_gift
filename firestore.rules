rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /messages/{messageId} {
      allow read: if true;
      allow write: if false;
    }

    match /notification_tokens/{tokenId} {
      allow read: if false;
      allow create, update: if
        request.resource.data.token == tokenId
        && request.resource.data.token is string
        && request.resource.data.token.size() > 20
        && request.resource.data.token.size() < 300
        && request.resource.data.ua is string
        && request.resource.data.ua.size() < 512
        && request.resource.data.keys().hasOnly(['token', 'ua', 'createdAt', 'updatedAt']);
      allow delete: if false;
    }
  }
}
